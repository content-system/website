{
  "compileOnSave": true,
  "compilerOptions": {
    "pretty": true,
    "target": "es6",
    "rootDir": "./",
    "outDir": "./",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "sourceMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "removeComments": true
  },
  "include": ["service/**/*.ts", "server.ts", "config.ts", "build/**/*.ts"],
  "exclude": ["node_modules", "./client"]
}
